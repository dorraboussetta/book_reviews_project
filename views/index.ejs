<%- include('partials/header.ejs'); %>
<body>
    <main class="container">
        <div class="container px-6">
            <div class="p-4 p-md-5 mb-4 rounded text-body-emphasis hero-section">
                <div class="col-lg-6 px-0">
                    <h1 class="display-4 fst-italic">Welcome To My Blog!</h1>
                    <p class="lead my-3">I read. A lot. 
                        <br/>
                        In this website, you'll find my reflections and ratings about books I've read so far. <br/> 
                        You can sort by 
                        <button type="submit" form="sortForm" name="sort" value="newest" class="text-link">
                        newest,   
                        </button>
                        <button type="submit" form="sortForm" name="sort" value="best" class="text-link">
                        best, 
                        </button>
                        , or 
                        <button type="submit" form="sortForm" name="sort" value="title" class="text-link">
                        title   
                        </button>
                        !
                        <br>
                        Happy reading! </p>
                        <form id="sortForm" action="/sort" method="post"></form>
                </div>
            </div>
            <% for(let book of books){ %>
                <div class="container my-6">
                    <figure>
                        <a href="<%= book.link %>"><img src= "<%= book.bookCoverLink %>" loading="lazy" alt=""></a>
                        <figcaption>
                            <h3 class="display-6"><a href="<%= book.link %>" ><%= book.title %></a></h3>
                            <br/>
                            <p class="lead">
                                <em>By <%= book.author%></em> 
                            </p>
                            <p class="lead">
                                Recommend it: <strong><%= book.rating %>/10.</strong>
                                <br/>
                                Date read: <time datetime=<%= book.date %>><%= book.date %></time>.
                            </p>
                            <p class="lead">
                                <%= book.shortNote %>
                            </p>
                            <form action="/book-info" method="get">
                                <input type="hidden" name="id" value="<%= book.id %>">
                                <button class="read-more-btn lead text-body-emphasis fw-bold"><i>Read More...</i></button>
                            </form>
                        </figcaption>
                    </figure>
                    <hr>
                </div>
            <% } %>
        </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
<%- include('partials/footer.ejs'); %>